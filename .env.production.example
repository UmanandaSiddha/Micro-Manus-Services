# Production env — copy to .env on the VPS next to docker-compose.yml. Mirrors
# .env.example section-for-section; only values differ. Postgres and Redis run
# as SEPARATE containers on the external docker network `shared-network`; the
# backend reaches them by container name, not localhost.

# ─────────── Image (CI/CD) ───────────
# The VPS never builds — CI pushes to GHCR and the deploy job pulls this tag
# (name derived from the GitHub repo, lowercased).
BACKEND_IMAGE="ghcr.io/umanandasiddha/micro-manus-services:latest"

# ─────────────── App ───────────────
NODE_ENV="production"
PORT="5000"
# Public URL of the deployed client
APP_URL="https://micromanus.example.com"
CORS_ORIGINS="https://micromanus.example.com"
# 'lax' if client+api share a site (app.x.com / api.x.com). 'none' (HTTPS required)
# if they live on unrelated domains (e.g. vercel.app client + VPS api).
COOKIE_SAMESITE="lax"

# ─────────── Infrastructure ───────────
# Container names on shared-network (adjust to the names of your pg/redis containers).
# Dedicated app user; bootstrap once as superuser: CREATE ROLE micromanus_user LOGIN
# PASSWORD '...'; CREATE DATABASE micromanus OWNER micromanus_user; then in that db:
# CREATE EXTENSION vector; (superuser-only, required before first deploy)
DATABASE_URL="postgresql://micromanus_user:<strong-password>@postgres:5432/micromanus?sslmode=disable"
REDIS_URL="redis://redis:6379"

# ─────────────── Secrets ─────────────── (generate fresh for prod!)
JWT_SECRET=""
ENCRYPTION_KEY=""

# ─────────── Firebase (sign-in) ───────────
# Also add the prod domain to Firebase -> Authentication -> Authorized domains.
FIREBASE_PROJECT_ID="micro-manus-c5b2a"
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

# ─────────── Stripe (test mode for the assignment) ───────────
STRIPE_SECRET_KEY="sk_test_..."
# From the Stripe dashboard webhook endpoint https://<api-domain>/api/billing/webhook
# (event: checkout.session.completed)
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─────────── Credits (spec defaults; override for demos) ───────────
CREDITS_PER_PURCHASE=5
COUPON_CREDITS=5

# ─────────── Admin ───────────
# This account is promoted to admin on sign-in (role survives even if unset later).
ADMIN_EMAIL=""

# ─────────── Agent services (ours) ───────────
TAVILY_API_KEY=""
VOYAGE_API_KEY=""

# ─────────────── Storage ───────────────
# Mounted volume inside the container (see docker-compose.yml)
ARTIFACTS_DIR="/app/data/artifacts"

# ─────────── Puppeteer ───────────
# Set by the Dockerfile; here for reference.
# PUPPETEER_EXECUTABLE_PATH="/usr/bin/chromium"
