DATABASE_URL=postgres://mm:mm@localhost:55432/micromanus?sslmode=disable
REDIS_URL=redis://localhost:56379
JWT_SECRET=<random 32+ chars>
ENCRYPTION_KEY=<64 hex chars>
APP_URL=http://localhost:3000
# Firebase service account (Console -> Project settings -> Service accounts -> Generate new private key)
FIREBASE_PROJECT_ID=micro-manus-c5b2a
FIREBASE_CLIENT_EMAIL=<client_email from the service account json>
# Paste private_key from the json AS-IS in double quotes; literal \n sequences are normalized at boot.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
TAVILY_API_KEY=tvly-...
VOYAGE_API_KEY=pa-...
ARTIFACTS_DIR=./data/artifacts
# CORS allowlist for the client origin(s), comma-separated
CORS_ORIGINS=http://localhost:3000
# 'lax' when client+api share a site; 'none' (forces Secure/HTTPS) when on unrelated domains
COOKIE_SAMESITE=lax
