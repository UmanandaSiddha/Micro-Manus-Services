# Copy to .env and fill in. Comments explain each value; see docs/deployment.md.

# ─────────────── App ───────────────
NODE_ENV="development"
# HTTP port the API listens on.
PORT="4000"
# Frontend origin (Stripe success/cancel URLs, cookie Secure flag)
APP_URL="http://localhost:3000"
# CORS allowlist for browser origins, comma-separated
CORS_ORIGINS="http://localhost:3000"
# 'lax' while client+api share a site; 'none' (forces Secure/HTTPS) on unrelated domains
COOKIE_SAMESITE="lax"

# ─────────── Infrastructure ───────────
# Local host Postgres (needs the pgvector extension available). dbmate reads this too.
DATABASE_URL="postgresql://postgres:password@localhost:5433/micromanus?sslmode=disable"
# Local Redis (BullMQ queues + run event pub/sub)
REDIS_URL="redis://localhost:6379"

# ─────────────── Secrets ───────────────
# Session JWT signing secret (openssl rand -hex 32)
JWT_SECRET=""
# AES-256-GCM key for user LLM API keys at rest — 64 hex chars (openssl rand -hex 32)
ENCRYPTION_KEY=""

# ─────────── Firebase (sign-in) ───────────
# Service account: Console -> Project settings -> Service accounts -> Generate new private key
FIREBASE_PROJECT_ID="micro-manus-c5b2a"
FIREBASE_CLIENT_EMAIL=""
# Paste private_key from the json AS-IS in double quotes; literal \n are normalized at boot.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─────────── Stripe (test mode) ───────────
STRIPE_SECRET_KEY="sk_test_..."
# From: stripe listen --forward-to localhost:4000/api/billing/webhook
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─────────── Agent services (ours) ───────────
# Tavily — the agent's web search
TAVILY_API_KEY="tvly-..."
# Voyage AI — conversation-memory embeddings
VOYAGE_API_KEY="pa-..."

# ─────────────── Storage ───────────────
ARTIFACTS_DIR="./data/artifacts"
